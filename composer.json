{
    "name": "heyosseus/vacuum",
    "description": "PostgreSQL monitoring for Laravel: wraparound, autovacuum, fillfactor-aware bloat, dead tuples, cache-hit ratio, stale statistics, and wasted indexes — each with the exact SQL to fix it. Shown, never run. Blade dashboard or Filament panel.",
    "keywords": [
        "laravel",
        "postgres",
        "postgresql",
        "database",
        "monitoring",
        "observability",
        "performance",
        "vacuum",
        "autovacuum",
        "dashboard"
    ],
    "license": "MIT",
    "homepage": "https://github.com/heyosseus/vacuum",
    "support": {
        "issues": "https://github.com/heyosseus/vacuum/issues",
        "source": "https://github.com/heyosseus/vacuum"
    },
    "authors": [
        {
            "name": "heyosseus",
            "email": "ratiruxadzee@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/view": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "filament/filament": "^4.0 || ^5.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.5 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.7 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.1 || ^4.0",
        "pestphp/pest-plugin-type-coverage": "^3.2 || ^4.0",
        "rector/rector": "^2.0",
        "symfony/var-dumper": "^7.1"
    },
    "suggest": {
        "filament/filament": "Serve Vacuum's UI inside a Filament v4 or v5 panel instead of the standalone Blade dashboard (^4.0 || ^5.0)."
    },
    "autoload": {
        "psr-4": {
            "Heyosseus\\Vacuum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heyosseus\\Vacuum\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Heyosseus\\Vacuum\\VacuumServiceProvider"
            ]
        }
    },
    "scripts": {
        "refacto": "rector",
        "lint": "pint",
        "test:refacto": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi --memory-limit=512M",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "pest --colors=always --coverage --min=100",
        "test": [
            "@test:refacto",
            "@test:lint",
            "@test:types",
            "@test:type-coverage",
            "@test:unit"
        ]
    }
}
